---
import SectionTitle from "../ui/SectionTitle.astro";
import TeamCard from "../ui/TeamCard.astro";
import Section from "./Section.astro";

import hifzaPic from "../../assets/pics/hifza-pic.webp"

const description =
  "Meet the skilled and experienced team behind our successful digital marketing strategies";


const team = [
  {
    pic: hifzaPic,
    name: "Hifza",
    role: "CEO",
    description:
      "3+ years of experience in paid search advertising. Skilled in campaign management and performance analysis",
    // link: "https://linkedin.com",
  },
];
---

<Section id="about">
  <div class="mt-[140px]">
    <SectionTitle sectionTitle="Team" description={description} />
    <div
      class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 grid-rows-2 gap-10"
    >
      {
        team.map((member, index) => (
          <TeamCard
            key={index}
            pic={member.pic}
            name={member.name}
            role={member.role}
            description={member.description}
          />
        ))
      }
    </div>
    <!-- <div class="flex justify-end mt-10">
      <button class="btn-primary">See all team</button>
    </div> -->
  </div>
</Section>
